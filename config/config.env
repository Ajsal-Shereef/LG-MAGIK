# Where to save the finetuned weights
OUTPUT_DIR=model_weights/flux

# Which model to load
PRETRAINED_MODEL_NAME_OR_PATH=flux

# Required: model family
MODEL_FAMILY=flux

# Flavour of flux
MODEL_FLAVOUR=dev   # or schnell, libreflux etc depending on what you use

# Full finetuning or lora
MODEL_TYPE=full

# Optimizer (bnb not available → use AdamW)
OPTIMIZER=adamw_bf16

# Base precision for VRAM savings
BASE_MODEL_PRECISION=no_change

# Training settings
TRAIN_BATCH_SIZE=4
NUM_TRAIN_EPOCHS=10
LEARNING_RATE=1e-6

# Validation
VALIDATION_PROMPT="Agent is in a room surrounded by blue walls."
VALIDATION_RESOLUTION=112x112
NUM_VALIDATION_IMAGES=2

DATALOADER_CONFIG = SimpleTuner/config/multidatabackend.json

# Training dataset directory
TRAIN_DATA_DIR=data/SimplePickup/training

# Validation dataset directory
VALIDATION_DATA_DIR=data/SimplePickup/validation
